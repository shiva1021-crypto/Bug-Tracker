# Copy this file to `.env` and adjust values for your environment.
# The app loads these via python-dotenv on startup. Never commit your real .env.

# ---- Application ----
# development | production
APP_ENV=development

# Session signing key.
# - In development this may be left blank: the app auto-generates one and
#   persists it to `.secret_key` so it survives restarts.
# - In production this MUST be set to a strong value (>= 32 chars, not a
#   default/placeholder). The app refuses to boot otherwise.
SECRET_KEY=

# ---- Database (MySQL) ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bug_tracker_db
DB_POOL_SIZE=5

# ---- Session cookie ----
# Send session cookie only over HTTPS. Leave false for local http dev.
SESSION_COOKIE_SECURE=false
# Session lifetime in seconds (default 8 hours).
SESSION_LIFETIME_SECONDS=28800

# ---- Base URL (Stage 10) ----
# Used to build links inside notification emails. Set this to your real
# domain in production (e.g. https://bugtracker.example.com).
APP_BASE_URL=http://127.0.0.1:5000

# ---- Email / SMTP (Stage 10) ----
# Leave SMTP_HOST blank to run with no mail server at all: notification
# rows still get written to the email_outbox table, they just never get
# sent (the background worker no-ops each cycle instead of erroring).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=bugtracker@example.com

# Set to false to disable the background email worker entirely (e.g. in a
# sandbox/CI environment with no SMTP available). Issue creation,
# assignment, and status changes all keep working either way -- only the
# email sending is skipped.
NOTIFICATION_WORKER_ENABLED=true
NOTIFICATION_WORKER_INTERVAL_SECONDS=10

# ---- Rate limiting (Stage 10) ----
# memory: simplest, per-process only. database: persists counters in
# auth_rate_limits, shared across multiple app instances.
RATELIMIT_STORAGE=memory
RATELIMIT_MAX_ATTEMPTS=5
RATELIMIT_WINDOW_SECONDS=900
